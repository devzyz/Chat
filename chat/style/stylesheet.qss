   color: black;
}

#forget_label[state='invisible_hover'], #forget_label[state='visible_hover']{
   color: rgb(42, 112, 241);
}

/* -------------- 主界面 最左侧的菜单栏的背景颜色 -------------- */
#side_bar_widget {
   background-color: rgb(46,46,46);
}

/* -------------- 主界面 上面搜索框后面的添加好友图标的移入移出状态 -------------- */
#add_btn[state='normal'] {
   border-image: url(:/res/add_friend_normal.png);
}

#add_btn[state='hover'] {
   border-image: url(:/res/add_friend_hover.png);
}

#add_btn[state='press'] {
   border-image: url(:/res/add_friend_hover.png);
}

/* -------------- 主界面 表情图标和文件图标的移入移出状态 -------------- */
#emoij_label[state='normal']{
   border-image: url(:/res/smile.png);
}

#emoij_label[state='hover']{
   border-image: url(:/res/smile_hover.png);
}

#emoij_label[state='press']{
   border-image: url(:/res/smile_press.png);
}

#file_label[state='normal']{
   border-image: url(:/res/filedir.png);
}

#file_label[state='hover']{
   border-image: url(:/res/filedir_hover.png);
}

#file_label[state='press']{
   border-image: url(:/res/filedir_press.png);
}

/* -------------- 主界面 搜索区域widget的背景颜色 -------------- */
#search_widget {
   background-color: rgb(247, 247, 247);
}

/* -------------- 登录界面/注册界面 错误提示的颜色设置 -------------- */
#err_tip[state='normal'] {
    color:green;
}

#err_tip[state='err'] {
    color:red;
}

/* -------------- 主界面 搜索框的边框大小 -------------- */
#search_edit {
   border: 2px solid #f1f1f1;
}

/* -------------- 主界面 搜索到好友后的弹出框的背景颜色 -------------- */
#FindSuccessDialog{
   background-color: #ffffff;
}

/* -------------- 主界面 搜索到好友后的弹出框，添加好友按钮的移入移出状态 -------------- */
#add_friend_btn[state='normal']{
   background: #07c160;
   color: #ffffff;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 20px; /* 设置圆角 */
}

#add_friend_btn[state='hover']{
   background: #3bbb4b;
   color: #ffffff;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 20px; /* 设置圆角 */
}

#add_friend_btn[state='press']{
   background: #07c160;
   color: #ffffff;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 20px; /* 设置圆角 */
}

/* -------------- 对所有的包含垂直滚动条的控件的滚动条执行下面的状态设计 -------------- */
QScrollBar:vertical {
   background: transparent; /* 将轨道背景设置为透明 */
   width: 8px; /* 滚动条宽度，根据需要调整 */
   margin: 0px; /* 移除滚动条与滑块之间的间距 */
}

QScrollBar::handle:vertical {
   background: rgb(173,170,169); /* 滑块颜色 */
   min-height: 10px; /* 滑块最小高度，根据需要调整 */
   border-radius: 4px; /* 滑块边缘圆角，调整以形成椭圆形状 */
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
   height: 0px; /* 移除上下按钮 */
   border: none; /* 移除边框 */
   background: transparent; /* 背景透明 */
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
   background: none; /* 页面滚动部分背景透明 */
}

/* -------------- 聊天页面，最下面的发送widget的背景颜色及边框 -------------- */
#send_widget{
   background: #ffffff;
   border: none; /* 隐藏边框 */
}

/* -------------- 聊天页面，中间工具栏（表情包和文件等）widget的背景颜色及边框 -------------- */
#tool_widget{
   background: #ffffff;
   border-bottom: 0.5px solid #ececec; /* 设置下边框颜色和宽度 */
}

/* -------------- 右侧用户信息页面 聊天、语音、视频的状态 -------------- */

#info_chat_label{
   border-image: url(:/res/chat_label.png);
}

#info_video_label{
   border-image: url(:/res/video_label.png);
}

#info_voice_label{
   border-image: url(:/res/voice_label.png);
}

/* -------------- 主界面 显示新消息的数量 -------------- */
QLabel#new_msg_count_label {
   background-color: #F44E4E;      /* 微信红色 */
   color: white;                   /* 白色数字 */
   border-radius: 9px;             /* 18px 的一半，完美圆形 */
   font-size: 10px;                /* 适合 18px 高度的字体 */
   font-weight: bold;
   padding: 0px;                   /* 防止内边距挤变形 */
}

#new_friend_item {
   border-bottom: 1px solid #eaeaea;
}

#LineItem {
   background-color:rgb(247,247,247);
   border: none;
}

#friend_apply_label {
   font-family: "Microsoft YaHei";
   font-size: 18px;
   font-weight: normal;
}

#friend_apply_widget {
   background-color: #f1f2f3;
   border-bottom: 1px solid #ede9e7;
}


