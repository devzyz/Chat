QDialog#LoginDialog, QDialog#RegisterDialog {
    background-color:rgb(255,255,255);
}

#user_label, #pass_label{
    color:black;
}

#user_chat_label{
   color:rgb(153,153,153);
   font-size: 12px;
   font-family: "Microsoft YaHei";
}

#user_name_label{
   color:rgb(0,0,0);
   font-size: 14px;
   font-weight: normal;
   font-family: "Microsoft YaHei";
}

#time_wideget #time_label{
   color:rgb(140,140,140);
   font-size: 12px;
   font-family: "Microsoft YaHei";
}



LoadingDialog{
   background: #f2eada;
}



#chat_edit{
   background: #ffffff;
   border: none; /* 隐藏边框 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   font-size: 18px; /* 设置字体大小 */
   padding: 5px; /* 设置内边距 */
}


#chat_data_list{
   background: #f0f0f0;
}

#chat_background{
   background: #f0f0f0;
}

#chat_scrollarea{
   border: none;
}


#invalid_item {
   background-color: #eaeaea;
   border: none;
}

#name_label{
   font-size: 14px;
   font-family: "Microsoft YaHei";
}

#ApplyFriend{
   border: 2px solid #f1f1f1;
   font-size: 14px;
   background: #f7f7f8;
}

#scrollArea{
   background: #f7f7f8;
   border: none;
}

#scrollcontent{
   background: #f7f7f8;
}

/* -------------- 聊天界面 最上部对方昵称的label设置 -------------- */
#title_label{
   font-family: "Microsoft YaHei";
   font-size: 18px;
   font-weight: normal;
}

/* -------------- 聊天界面 聊天区域背景等设置 -------------- */
#chat_detail_data_list {
   background-color: rgb(240, 240, 240);
   border: none
}

#chat_detail_data_list::item {
   background: transparent;
}

#chat_detail_data_list::item:selected {
   background: transparent;
}

/* -------------- 设置红点的背景 -------------- */
#red_point {
   border-image: url(:/res/red_point.png);
}

/* -------------- 侧边栏 聊天、联系人 样式 -------------- */
#side_chat_label[state='leave']{
   border-image: url(:/res/chat_leave.png);
}

#side_chat_label[state='hover']{
   border-image: url(:/res/chat_hover.png);
}

#side_chat_label[state='select']{
   border-image: url(:/res/chat_select.png);
}

#side_user_label[state='leave']{
   border-image: url(:/res/user_leave.png);
}

#side_user_label[state='hover']{
   border-image: url(:/res/user_hover.png);
}

#side_user_label[state='select']{
   border-image: url(:/res/user_select.png);
}

/* -------------- 聊天列表 Item 样式 -------------- */
#chat_user_Item {
   background-color: rgb(0, 0, 0);
}

/* -------------- 聊天列表 QListWidget（chat_user_list） 样式 -------------- */
#chat_user_list {
   background-color: rgb(247, 247, 248);
   border: none;
}

#chat_user_list::item:selected {
   background-color: #d3d7d4;
   border: none;
   outline: none;
}

#chat_user_list::item:hover {
   background-color: rgb(206,207,208);
   border: none;
   outline: none;
}

#chat_user_list::focus {
   border: none;
   outline: none;
}

/* -------------- 联系人列表 QListWidget（contact_user_list） 样式 -------------- */
#contact_user_list {
   background-color: rgb(247,247,248);
   border: none;
}

#contact_user_list::item:selected {
   background-color: #d3d7d4;
   border: none;
   outline: none;
}

#contact_user_list::item:hover {
   background-color: rgb(206,207,208);
   border: none;
   outline: none;
}

#contact_user_list::focus {
   border: none;
   outline: none;
}

/* -------------- 新朋友申请列表 QListWidget（apply_friend_list） 的样式 -------------- */

#apply_friend_list {
   background-color: #f1f2f3;
   border-left: 1px solid #ede9e7;
   border-top: none;
   border-right: none;
   border-bottom: none;
}

/* -------------- 搜索结果列表 QListWidget（search_list） 的样式 -------------- */
#search_list {
   background-color: rgb(247,247,248);
   border: none;
}

#search_list::item:selected {
   background-color: #d3d7d4;
   border: none;
   outline: none;
}

#search_list::item:hover {
   background-color: rgb(206,207,208);
   border: none;
   outline: none;
}

#search_list::focus {
   border: none;
   outline: none;
}

/* -------------- AddUserItem 的样式 -------------- */
#add_user_tip {
   border-image: url(:/res/add_tip.png);
}

#add_user_right_tip {
   border-image: url(:/res/right_tip.png);
}

#add_user_message_tip {
  text-align: center;
  font-family: "Microsoft YaHei";
  font-size: 12pt;
}

/* -------------- GroupTipItem 的样式 -------------- */
#GroupTipItem {
   background-color: #eaeaea;
   border: none;
}

#GroupTipItem QLabel{
   color: #2e2f30;
   font-size: 12px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border: none;
}

/* -------------- ApplyFriendItem 的样式 -------------- */
ApplyFriendItem {
   background-color: #f1f2f3;
   border-bottom: 2px solid #dbd9d9;
}

ApplyFriendItem #apply_friend_user_chat_label{
   color: #a2a2a2;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
}

ApplyFriendItem #apply_friend_add_friend_btn[state='normal'] {
   background-color: #d3d7d4;
   color: #2cb46e;
   font-size: 16px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 20px; /* 设置圆角 */
}

ApplyFriendItem #apply_friend_add_friend_btn[state='hover'] {
   background-color: #D3D3D3;
   color: #2cb46e;
   font-size: 16px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 20px; /* 设置圆角 */
}

ApplyFriendItem #apply_friend_add_friend_btn[state='press'] {
   background-color: #BEBEBE;
   color: #2cb46e;
   font-size: 16px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 20px; /* 设置圆角 */
}

/* -------------- 注册时，密码与确认密码的隐藏与显示 -------------- */
#password_visible[state='invisible_leave']{
   border-image: url(:/res/normal_leave.png);
}
#password_visible[state='invisible_hover']{
   border-image: url(:/res/normal_hover.png);
}
#password_visible[state='invisible_press']{
   border-image: url(:/res/normal_hover.png);
}
#password_visible[state='visible_leave']{
   border-image: url(:/res/select_leave.png);
}
#password_visible[state='visible_hover']{
   border-image: url(:/res/select_hover.png);
}
#password_visible[state='visible_press']{
   border-image: url(:/res/select_hover.png);
}

#confirm_visible[state='invisible_leave']{
   border-image: url(:/res/normal_leave.png);
}
#confirm_visible[state='invisible_hover']{
   border-image: url(:/res/normal_hover.png);
}
#confirm_visible[state='invisible_press']{
   border-image: url(:/res/normal_hover.png);
}
#confirm_visible[state='visible_leave']{
   border-image: url(:/res/select_leave.png);
}
#confirm_visible[state='visible_hover']{
   border-image: url(:/res/select_hover.png);
}
#confirm_visible[state='invisible_press']{
   border-image: url(:/res/normal_hover.png);
}

